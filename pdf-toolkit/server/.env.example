# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=your_mongodb_connection_string

# JWT
JWT_SECRET=your_super_secret_key_min_32_chars

# Flutterwave
FLW_PUBLIC_KEY=FLWPUBK_TEST-your_public_key
FLW_SECRET_KEY=FLWSECK_TEST-your_secret_key
FLW_ENCRYPTION_KEY=FLWSECK_TEST-your_encryption_key
FLW_WEBHOOK_HASH=your_flutterwave_webhook_hash
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_PAYMENT_PLAN_ID=
PREMIUM_AMOUNT=5
PREMIUM_CURRENCY=USD

# SendGrid (Option 1 - for production)
SENDGRID_API_KEY=SG.your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Gmail SMTP (Option 2 - for development/testing)
# Use this instead of SendGrid if you prefer Gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
# Optional explicit SMTP settings (defaults provided in code)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Client URL
CLIENT_URL=http://localhost:3000

# File Upload Limits
MAX_FILE_SIZE_FREE=10485760
MAX_FILE_SIZE_PREMIUM=52428800

# Rate Limiting
FREE_CONVERSIONS_PER_HOUR=3

# Redis Configuration (NEW)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Socket.io (NEW)
SOCKET_URL=http://localhost:5000

# LibreOffice Path (NEW)
LIBREOFFICE_PATH=C:\\Program Files\\LibreOffice\\program\\soffice.exe

# OCR Settings (NEW)
FREE_OCR_PER_MONTH=10
OCR_MAX_FILE_SIZE=20971520
OCR_LANGUAGES=eng

# PDF to Image Settings (NEW)
PDF_TO_IMAGE_DPI=300
PDF_TO_IMAGE_FORMAT=png
